{
  "name": "@lawchers/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "lawchers": "./dist/src/bin.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
